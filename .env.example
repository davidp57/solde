# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Solde

DEBUG=false
# Enable Swagger UI / ReDoc at /api/docs and /api/redoc (disabled by default in production)
SWAGGER_ENABLED=false

# ── Database ─────────────────────────────────────────────────────────────────
# In Docker deployments, keep this value unchanged (`./data` is mounted to `/app/data`)
DATABASE_URL=sqlite+aiosqlite:///data/solde.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters — required
JWT_SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_VALEUR_SECRETE_D_AU_MOINS_32_CARACTERES
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Temporary import shortcuts (development only) ───────────────────────────
ENABLE_TEST_IMPORT_SHORTCUTS=false
TEST_IMPORT_GESTION_2024_PATH=
TEST_IMPORT_GESTION_2025_PATH=
TEST_IMPORT_COMPTABILITE_2024_PATH=
TEST_IMPORT_COMPTABILITE_2025_PATH=

# ── Fiscal year ──────────────────────────────────────────────────────────────
# Start month (1=January … 12=December). Default: 8 (August)
FISCAL_YEAR_START_MONTH=8

# ── Bootstrap administrator account ──────────────────────────────────────────
# Used only when no user exists yet on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@exemple.fr

# ── Association information and SMTP ────────────────────────────────────────
# These settings are configured through the application settings UI,
# not through environment variables.
