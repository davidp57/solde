# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Solde
APP_VERSION=0.1.0
DEBUG=false

# ── Base de données ───────────────────────────────────────────────────────────
# En production Docker, ne pas modifier (le volume ./data est monté dans /app/data)
DATABASE_URL=sqlite+aiosqlite:///data/solde.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 caractères — obligatoire
JWT_SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_VALEUR_SECRETE_D_AU_MOINS_32_CARACTERES
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Raccourcis d'import temporaires (développement) ─────────────────────────
ENABLE_TEST_IMPORT_SHORTCUTS=false
TEST_IMPORT_GESTION_2024_PATH=
TEST_IMPORT_GESTION_2025_PATH=
TEST_IMPORT_COMPTABILITE_2024_PATH=
TEST_IMPORT_COMPTABILITE_2025_PATH=

# ── Exercice comptable ────────────────────────────────────────────────────────
# Mois de début (1=janvier … 12=décembre). Défaut : 8 (août)
FISCAL_YEAR_START_MONTH=8

# ── Compte administrateur bootstrap ───────────────────────────────────────────
# Utilisé uniquement si aucun utilisateur n'existe encore au premier démarrage
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@exemple.fr

# ── Informations association (factures, e-mails) ─────────────────────────────
ASSOCIATION_NAME=Mon Association
ASSOCIATION_ADDRESS=
ASSOCIATION_SIRET=
ASSOCIATION_LOGO_PATH=

# ── SMTP (optionnel — pour l'envoi de factures par e-mail) ───────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=votre.adresse@example.com
# SMTP_PASSWORD=votre_mot_de_passe
# SMTP_FROM_EMAIL=noreply@votre-association.fr
# SMTP_USE_TLS=true
